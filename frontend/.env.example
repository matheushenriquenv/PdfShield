# PDFShield Frontend — Variáveis de Ambiente
# Copiar para .env.local e preencher

# URL do backend FastAPI
BACKEND_URL=http://localhost:8000

# URL pública do site
NEXT_PUBLIC_BASE_URL=https://pdfshield.app

# Stripe (chave pública — segura para o browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe (chave secreta — NUNCA expor no browser)
STRIPE_SECRET_KEY=sk_live_...

# ID do PDF base (UUID retornado pelo /api/pdfs/upload)
NEXT_PUBLIC_DEFAULT_PDF_ID=cole-aqui-o-uuid-do-pdf
