# PDFShield Backend — Variáveis de Ambiente
# Copiar para .env e preencher antes de subir

# ── URLs ────────────────────────────────────────────────────────────────────
BASE_URL=https://pdfshield.app
FRONTEND_URL=https://pdfshield.app

# ── Produto ──────────────────────────────────────────────────────────────────
PRODUCT_PRICE_CENTS=9700        # R$ 97,00 (em centavos para Stripe)
PRODUCT_PRICE_BRL=97.00         # R$ 97,00 (para Mercado Pago)

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Mercado Pago ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-...

# ── E-mail ───────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend           # ou: sendgrid
RESEND_API_KEY=re_...
# SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@pdfshield.app
EMAIL_FROM_NAME=PDFShield

# ── Banco de Dados (PostgreSQL) ───────────────────────────────────────────────
# Em produção substituir os stores em memória por queries SQL
DATABASE_URL=postgresql+asyncpg://pdfshield:senha@localhost/pdfshield

# ── AWS S3 (armazenamento de PDFs) ───────────────────────────────────────────
# Em produção substituir _pdfs e protected_pdf pelo S3
AWS_S3_BUCKET=pdfshield-pdfs
AWS_S3_REGION=sa-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
